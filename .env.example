# Copy this file to `.env` and paste in your keys.
# Never commit .env — it's in .gitignore.

# Anthropic (Claude) — required for most lessons
ANTHROPIC_API_KEY=

# OpenAI (GPT) — modules 5, 8, 9
OPENAI_API_KEY=

# Google AI Studio (Gemini) — modules 4, 7
GOOGLE_API_KEY=

# LangFuse — lesson 5.6 only (LLM observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Pinecone — module 6 RAG (optional; Chroma works locally without keys)
PINECONE_API_KEY=

# Hugging Face — modules 4, 7 (only for gated models)
HF_TOKEN=
